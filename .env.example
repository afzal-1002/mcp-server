# ============================================================
# ATOS AI Resolution Engine — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.
# ============================================================

# --- Shared across all services ---
DB_USERNAME=mafzal
DB_PASSWORD=your_db_password_here
EUREKA_URL=http://localhost:8761/eureka/
JWT_SECRET=your_strong_jwt_secret_at_least_32_bytes_here
JWT_EXPIRATION_MS=3600000

# --- Per-service DB URLs (override if not using defaults) ---
# DB_URL=jdbc:mysql://localhost:3306/<service_db>?...

# --- USER-SERVICE ---
PROJECT_SERVICE_URL=http://localhost:8082
CRYPTO_PASSWORD=your_crypto_password_here
CRYPTO_SALT=your_16_char_hex_salt

# --- MCP-SERVER ---
MCP_SERVER_PORT=8084
JIRA_API_VERSION=3
JIRA_DEFAULT_MAX_RESULTS=25
USER_SERVICE_URL=http://localhost:8081
PROJECT_SERVICE_URL=http://localhost:8082
GITHUB_HOST=github.gsissc.myatos.net
GITHUB_API_BASE_URL=
GITHUB_BASE_BRANCH=main
GITHUB_COPILOT_CUSTOM_AGENT=
GITHUB_COPILOT_MODEL=
GITHUB_COPILOT_ASSIGNEE=copilot-swe-agent[bot]
GITHUB_API_VERSION=2022-11-28

# --- ISSUES-SERVICE ---
USER_SERVICE_URL=http://localhost:8081
